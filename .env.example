# -----------------------------------------------------------------------------
# Polymarket — Phases 5 & 6
# -----------------------------------------------------------------------------
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/

# -----------------------------------------------------------------------------
# Polygon wallet — Phase 6
# Use your own node (localhost) or a single dedicated RPC endpoint.
# Public RPCs are explicitly disallowed by SPEC.md Step 6.1.
# -----------------------------------------------------------------------------
POLYGON_RPC_URL=http://localhost:8545
POLYGON_WALLET_ADDRESS=
POLYGON_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Deribit — Phase 1.2 (BTC IV, term structure, skew)
# -----------------------------------------------------------------------------
DERIBIT_API_KEY=
DERIBIT_API_SECRET=

# -----------------------------------------------------------------------------
# LLM circuit breaker — Phase 4
# Pick one provider and leave the other blank.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# News feed for circuit breaker context
NEWS_API_KEY=

# -----------------------------------------------------------------------------
# Database — Phase 1 onward
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://localhost:5432/pmbot

# -----------------------------------------------------------------------------
# Paths (override if you want data/models/logs elsewhere)
# -----------------------------------------------------------------------------
DATA_ROOT=./data
MODEL_ROOT=./models
LOG_ROOT=./logs